<?xml version="1.0" encoding="utf-8"?>
<ClassSaverConfig>
    <!-- Markers -->
    <Markers>
        <Marker name="StartPrimitive" value="23" byteType="StartByte"/>
        <Marker name="StartSerializable" value="24" byteType="StartByte"/>
        <Marker name="StartCollection" value="25" byteType="StartByte"/>
        <Marker name="StartClass" value="26" byteType="StartByte"/>
        <Marker name="StartSection" value="27" byteType="StartByte"/>
        <Marker name="EndScope" value="28" byteType="EndByte"/>
    </Markers>

    <!-- Datatype map 
    Note: Type name MUST match the appropriate name for primitive data type.
    -->
    
    <TypeMap>
        <Type name="Boolean" code="5" type="struct"/>
        <Type name="Byte" code="6" type="struct"/>
        <Type name="SByte" code="7" type="struct"/>
        <Type name="Char" code="8" type="struct"/>
        <Type name="Int16" code="9" type="struct"/>
        <Type name="UInt16" code="10" type="struct"/>
        <Type name="Int32" code="11" type="struct"/>
        <Type name="UInt32" code="12" type="struct"/>
        <Type name="Int64" code="13" type="struct"/>
        <Type name="UInt64" code="14" type="struct"/>
        <Type name="Single" code="15" type="struct"/>
        <Type name="Double" code="16" type="struct"/>
        <Type name="IntPtr" code="17" type="struct"/>
        <Type name="UIntPtr" code="18" type="struct"/>
        <Type name="String" code="19" type="class"/>
        <Type name="Decimal" code="20" type="struct"/>
        <!-- Custom user-set serializable data is also considered a primitive data type. -->
        <Type name="ISerializable" code="21" type="interface"/>
    </TypeMap>
    
</ClassSaverConfig>