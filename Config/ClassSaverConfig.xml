<?xml version="1.0" encoding="utf-8"?>
<ClassSaverConfig>
    <!-- Markers -->
    <Markers>
        <Marker name="StartVariable" value="23"/>
        <Marker name="StartSerializable" value="24"/>
        <Marker name="StartEnumerable" value="25"/>
        <Marker name="StartClass" value="26"/>
        <Marker name="StartSection" value="27"/>
        <Marker name="EndScope" value="28"/>
    </Markers>

    <!-- Datatype map 
    Note: Type name MUST match the appropriate name for primitive data type.
    -->
    
    <TypeMap>
        <Type name="Boolean" code="5"/>
        <Type name="Byte" code="6"/>
        <Type name="SByte" code="7"/>
        <Type name="Char" code="8"/>
        <Type name="Int16" code="9"/>
        <Type name="UInt16" code="10"/>
        <Type name="Int32" code="11"/>
        <Type name="UInt32" code="12"/>
        <Type name="Int64" code="13"/>
        <Type name="UInt64" code="14"/>
        <Type name="Single" code="15"/>
        <Type name="Null" code="16"/>
        <Type name="Double" code="17"/>
        <Type name="IntPtr" code="18"/>
        <Type name="UIntPtr" code="19"/>
        <Type name="String" code="20"/>
        <Type name="Decimal" code="21"/>
        <!-- Custom user-set serializable data is also considered a primitive data type. -->
        <Type name="ISerializable" code="22"/>
    </TypeMap>
    
</ClassSaverConfig>